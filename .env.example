# Empty values only. Configure real values in the worker secret manager.
BROWSERLESS_TOKEN=""
AW_PORTAL_EMAIL=""
AW_PORTAL_PASSWORD=""
PLACE_PORTAL_EMAIL=""
PLACE_PORTAL_PASSWORD=""
MAXIMILIEN_PORTAL_EMAIL=""
MAXIMILIEN_PORTAL_PASSWORD=""

# Autonomous DCE recovery is one-shot and stays inert by default.
RECOVERY_MODE="off"
RECOVERY_BATCH_SIZE="25"

# READER stays off until an operator explicitly selects dry_run or apply.
READER_MODE="off"
READER_BATCH="2"
OPENROUTER_MODEL_EXTRACT="google/gemini-3.5-flash"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
OPENROUTER_API_KEY=""
NUKEMA_USERNAME=""
NUKEMA_PASSWORD=""

# ANALYZE is an independent one-shot worker and stays inert by default.
ANALYZE_MODE="off"
OPENROUTER_MODEL_SCORE="openai/gpt-5.6-terra"
ANALYZE_MAX_STEPS="8"
ANALYZE_MAX_OUTPUT_TOKENS="8192"
